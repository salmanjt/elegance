{
    "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
    "version": 2,
    "final_space": true,
    "palette": {
        "bg": "#4F5C6C",
        "fg": "#d5dee1",
        "gray": "#8090a3",
        "red": "#e87a78",
        "orange": "#f69d6a",
        "yellow": "#efd671",
        "green": "#85db8a",
        "blue": "#87bed9",
        "cyan": "#99c7c7",
        "purple": "#bea8e1"
    },
    "transient_prompt": {
        "background": "transparent",
        "foreground": "p:bg",
        "template": "\ueb70 "
    },
    "blocks": [
        {
            "type": "prompt",
            "alignment": "left",
            "segments": [
                {
                    "type": "text",
                    "style": "plain",
                    "foreground": "p:bg",
                    "foreground_templates": [
                        "{{ if gt .Code 0 }}p:red{{ end }}"
                    ],
                    "template": "\u256d\u2500",
                    "properties": {
                        "always_enabled": true
                    }
                },
                {
                    "type": "text",
                    "style": "plain",
                    "foreground": "p:bg",
                    "template": "\ue0b2",
                    "properties": {
                        "always_enabled": true
                    }
                },
                {
                    "type": "root",
                    "background": "p:bg",
                    "foreground": "p:red",
                    "style": "powerline",
                    "template": " \uf0e7"
                },
                {
                    "type": "path",
                    "background": "p:bg",
                    "foreground": "p:fg",
                    "style": "diamond",
                    "leading_diamond": "",
                    "trailing_diamond": "\ue0b0",
                    "template": " {{ .Path }} ",
                    "properties": {
                        "home_icon": "~",
                        "folder_icon": "..\ue5fe..",
                        "folder_separator_icon": "/",
                        "style": "agnoster_short"
                    }
                },
                {
                    "type": "git",
                    "background": "p:bg",
                    "foreground": "p:blue",
                    "foreground_templates": [
                        "{{ if or (.Working.Changed) (.Staging.Changed) }}p:orange{{ end }}",
                        "{{ if and (gt .Ahead 0) (gt .Behind 0) }}p:red{{ end }}",
                        "{{ if gt .Ahead 0 }}p:purple{{ end }}",
                        "{{ if gt .Behind 0 }}p:purple{{ end }}"
                    ],
                    "style": "diamond",
                    "leading_diamond": "",
                    "trailing_diamond": "\ue0b0",
                    "template": "[{{ url .UpstreamIcon .UpstreamURL }} {{ .HEAD }}{{if .BranchStatus }} {{ .BranchStatus }}{{ end }}{{ if .Working.Changed }} \uf044 {{ .Working.String }}{{ end }}{{ if and (.Working.Changed) (.Staging.Changed) }} |{{ end }}{{ if .Staging.Changed }} \uf046 {{ .Staging.String }}{{ end }}{{ if gt .StashCount 0 }} \uf692 {{ .StashCount }}{{ end }}] ",
                    "properties": {
                        "branch_icon": "\ue0a0",
                        "fetch_stash_count": true,
                        "fetch_status": true,
                        "fetch_upstream_icon": true,
                        "fetch_worktree_count": true
                    }
                }
            ]
        },
        {
            "type": "prompt",
            "alignment": "right",
            "overflow": "break",
            "segments": [
                {
                    "type": "executiontime",
                    "background": "p:bg",
                    "foreground": "p:fg",
                    "style": "diamond",
                    "leading_diamond": "\ue0b2",
                    "template": " \uf64f {{ .FormattedMs }}<transparent,p:bg> │ </>",
                    "properties": {
                        "style": "austin",
                        "threshold": 0
                    }
                },
                {
                    "type": "python",
                    "background": "p:bg",
                    "foreground": "p:green",
                    "style": "diamond",
                    "template": "\ue235 {{ if .Error }}{{ .Error }}{{ else }}{{ if .Venv }}{{ .Venv }}{{ end }}{{ .Full }}{{ end }}<transparent,p:bg> │ </>",
                    "properties": {
                        "fetch_version": false
                    }
                },
                {
                    "type": "node",
                    "background": "p:bg",
                    "foreground": "p:green",
                    "style": "diamond",
                    "template": "\ue718 {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }}<transparent,p:bg> │ </>",
                    "properties": {
                        "fetch_package_manager": true,
                        "npm_icon": "<p:red>\ue71e</> ",
                        "yarn_icon": "<p:blue>\uf61a</> "
                    }
                },
                {
                    "type": "r",
                    "background": "p:bg",
                    "foreground": "p:blue",
                    "style": "diamond",
                    "template": "R {{ if .Error }}{{ .Error }}{{ else }}{{ .Full }}{{ end }}<transparent,p:bg> │ </>"
                },
                {
                    "type": "shell",
                    "background": "p:bg",
                    "foreground": "p:fg",
                    "trailing_diamond": "\ue0b0",
                    "style": "diamond",
                    "template": "\uf489 {{ .Name }} "
                },
                {
                    "type": "text",
                    "style": "plain",
                    "foreground": "p:bg",
                    "template": "\u2500",
                    "properties": {
                        "always_enabled": true
                    }
                },
                {
                    "type": "os",
                    "background": "transparent",
                    "foreground": "p:fg",
                    "style": "diamond",
                    "leading_diamond": "<p:bg></>",
                    "trailing_diamond": "<p:bg></>",
                    "template": "{{ if .WSL }}WSL at {{ end }}{{.Icon}}",
                    "properties": {
                        "windows": "\ue62a",
                        "ubuntu": "\uf31b",
                        "linux": "\uf17c",
                        "macos": "\ue635"
                    }
                }
            ]
        },
        {
            "type": "prompt",
            "alignment": "left",
            "newline": true,
            "segments": [
                {
                    "type": "exit",
                    "style": "plain",
                    "foreground": "p:bg",
                    "foreground_templates": [
                        "{{ if gt .Code 0 }}p:red{{ end }}"
                    ],
                    "template": "\u2570\u2500\ueb70",
                    "properties": {
                        "always_enabled": true
                    }
                }
            ]
        }
    ]
}
